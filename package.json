{
  "name": "gtm-company-enrichment",
  "version": "0.1.0",
  "description": "Bacca enrichment pipeline + one-page web UI. Upload a CSV, optionally push to Attio, download the resulting enrichment as CSV.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "enrich-all": "tsx src/index.ts enrich-all",
    "ui": "concurrently -k -n SERVER,WEB -c blue,magenta \"npm:server:dev\" \"npm:web:dev\"",
    "server:dev": "tsx watch server/index.ts",
    "web:dev": "vite --config web/vite.config.ts",
    "build": "vite build --config web/vite.config.ts",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "apify-client": "^2.9.3",
    "axios": "^1.7.2",
    "bottleneck": "^2.19.5",
    "commander": "^14.0.3",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.0",
    "dotenv": "^16.4.5",
    "exa-js": "^2.11.0",
    "express": "^4.21.2",
    "multer": "^2.0.0",
    "openai": "^4.52.0",
    "p-limit": "^5.0.0",
    "tsx": "^4.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tanstack/react-table": "^8.21.3",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
