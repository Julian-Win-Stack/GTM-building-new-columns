{
  "name": "gtm-company-enrichment",
  "version": "0.1.0",
  "description": "Backend script that enriches company data via Apify, Exa, TheirStack, and OpenAI, reading from input.csv and writing to output.csv with resumable state.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test-run": "node src/index.js --limit 5",
    "retry-errors": "node src/index.js --retry-errors"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "apify-client": "^2.9.3",
    "axios": "^1.7.2",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.0",
    "dotenv": "^16.4.5",
    "openai": "^4.52.0",
    "p-limit": "^5.0.0"
  }
}
