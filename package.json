{
  "name": "gtm-company-enrichment",
  "version": "0.1.0",
  "description": "Backend script that enriches company data via Apify, Exa, TheirStack, and OpenAI, reading from input.csv and writing to output.csv with resumable state.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "enrich-all": "tsx src/index.ts enrich-all",
    "enrich-company": "tsx src/index.ts enrich-company",
    "enrich-column": "tsx src/index.ts enrich-column",
    "attio-smoke": "tsx src/index.ts attio-smoke",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "apify-client": "^2.9.3",
    "axios": "^1.7.2",
    "commander": "^14.0.3",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.0",
    "dotenv": "^16.4.5",
    "exa-js": "^2.11.0",
    "openai": "^4.52.0",
    "p-limit": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.4"
  }
}
