# ──────────────────────────────────────────────────────────────────────────
# 1. API keys (required)
# ──────────────────────────────────────────────────────────────────────────
APIFY_TOKEN=
EXA_API_KEY=
THEIRSTACK_API_KEY=
APOLLO_API_KEY=

# Comma-separated for multiple keys (3x throughput with 3 keys). Single key also accepted as X_API_KEY=.
X_API_KEYS=

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=https://<resource>.openai.azure.com/openai/v1
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_DEPLOYMENT_PRO=gpt-5.4-pro

# ──────────────────────────────────────────────────────────────────────────
# 2. Attio
# ──────────────────────────────────────────────────────────────────────────
ATTIO_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# 3. Concurrency
# ──────────────────────────────────────────────────────────────────────────
CONCURRENCY=3
ATTIO_WRITE_CONCURRENCY=5
OPENAI_CONCURRENCY=5
APIFY_CONCURRENCY=10
STATUSPAGE_CONCURRENCY=20

# ──────────────────────────────────────────────────────────────────────────
# 4. Per-API rate limits + retries
# ──────────────────────────────────────────────────────────────────────────
EXA_QPS=5
EXA_RETRY_TRIES=3
EXA_RETRY_BASE_MS=1000

THEIRSTACK_QPS=3.5
THEIRSTACK_RETRY_TRIES=3
THEIRSTACK_RETRY_BASE_MS=1000

APOLLO_QPS=3
APOLLO_RETRY_TRIES=3
APOLLO_RETRY_BASE_MS=1000

APIFY_RETRY_TRIES=3
APIFY_RETRY_BASE_MS=2000

# Per-key. With X_API_KEYS=k1,k2,k3 the effective ceiling is 3 × TWITTER_API_QPS.
TWITTER_API_QPS=19
TWITTER_API_RETRY_TRIES=3
TWITTER_API_RETRY_BASE_MS=1000

STATUSPAGE_RETRY_TRIES=3
STATUSPAGE_RETRY_BASE_MS=1000

# ──────────────────────────────────────────────────────────────────────────
# 5. Server (web UI only — the CLI ignores these)
# ──────────────────────────────────────────────────────────────────────────
# Used by `npm run ui`, `npm run server:dev`, `npm start`.
PORT=3001
NODE_ENV=development
# Where uploaded CSVs land. On Railway with a persistent volume, set to /data/uploads.
UPLOAD_DIR=tmp/uploads
# Where crash-recovery snapshots are written. On Railway with a persistent volume, set to /data/runs.
SNAPSHOT_DIR=tmp/runs
